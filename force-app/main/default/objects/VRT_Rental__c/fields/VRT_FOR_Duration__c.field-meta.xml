<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VRT_FOR_Duration__c</fullName>
    <description>Este campo de fórmula calculará la duración del periodo de alquiler en días, basándose en las fechas de inicio y fin.</description>
    <externalId>false</externalId>
    <formula>VRT_DAT_FinalDate__c  -  VRT_DAT_InitialDate__c</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Duración</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
